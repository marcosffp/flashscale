{
  "name": "flashscale",
  "version": "0.1.0",
  "private": true,
  "description": "Flash Sale Black Friday — MVP Kubernetes",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "ts-node services/api/src/main.ts",
    "start:dev": "ts-node-dev --respawn --transpile-only services/api/src/main.ts",
    "start:prod": "node dist/services/api/src/main.js",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d services/api/src/config/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d services/api/src/config/data-source.ts",
    "start:gateway": "ts-node services/gateway/src/main.ts",
    "start:gateway:dev": "ts-node-dev --respawn --transpile-only services/gateway/src/main.ts",
    "start:gateway:prod": "node dist/services/gateway/src/main.js",
    "start:orchestrator": "ts-node services/orchestrator/src/main.ts",
    "start:orchestrator:dev": "ts-node-dev --respawn --transpile-only services/orchestrator/src/main.ts",
    "start:orchestrator:prod": "node dist/services/orchestrator/src/main.js",
    "dashboard:install": "npm --prefix dashboard install",
    "dashboard:dev": "npm --prefix dashboard run dev",
    "dashboard:build": "npm --prefix dashboard run build",
    "dashboard:test": "npm --prefix dashboard run test",
    "test:integration": "dotenv -e .env.test -- npm run migration:run && dotenv -e .env.test -- jest --config config/jest.integration.config.js --runInBand",
    "test:unit": "jest --config config/jest.unit.config.js",
    "test:load": "k6 run tests/load/pedidos-load.js",
    "lint": "eslint --config config/eslint.config.mjs services tests",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@kubernetes/client-node": "1.0.0-rc7",
    "@nestjs/axios": "^3.1.3",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-ws": "^10.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.0",
    "axios": "^1.7.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "dotenv-cli": "^7.4.2",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.64.0",
    "uuid": "^11.1.1"
  },
  "overrides": {
    "multer": "^2.2.0",
    "qs": "^6.15.3",
    "ws": "^8.21.1",
    "lodash": "^4.18.1",
    "uuid": "^11.1.1",
    "file-type": "^21.3.4"
  }
}
